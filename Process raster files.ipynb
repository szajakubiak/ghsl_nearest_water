   "source": [
    "import geopandas as gpd\n",
    "import glob\n",
    "import rioxarray as rxr\n",
    "import xarray as xr"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "328d5f7d-5c40-492f-a204-e988386e2116",
   "metadata": {},
   "outputs": [],
   "source": [
    "PATH = \"data/GHS_LAND_*.tif\"\n",
    "AOI = \"aoi/A00_Granice_panstwa.shp\""
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "b95e1030-c2e9-4d02-8c2e-48c227809085",
   "metadata": {},
   "outputs": [],
   "source": [
    "files = glob.glob(PATH)\n",
    "\n",
    "arrays = []\n",
    "\n",
    "for file in files:\n",
    "    arrays.append(rxr.open_rasterio(file, masked=True, chunks=\"10\"))"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "e43d0f32-8f65-4081-99ce-222f6f5e5963",
   "metadata": {},
   "outputs": [],
   "source": [
    "array = arrays[1]"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "10d064a9-0fd2-4835-a286-7ae655feb850",
   "metadata": {},
   "outputs": [],
   "source": [
    "array = array.astype(\"byte\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "23e9edd4-fcd6-4e82-8b8e-92c6e1fe35a4",
   "metadata": {},
   "outputs": [],
   "source": [
    "array.values = np.where(array < 25, 0, 1)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "6d981c9b-88f8-4660-9c8b-dbd7b153dca7",
   "metadata": {},
   "outputs": [],
   "source": [
    "array.rio.to_raster(\n",
    "    \"output.tif\", \n",
    "    compress=\"lzw\", \n",
    "    dtype=\"byte\",\n",
    ")"
   ]
  },
  }
